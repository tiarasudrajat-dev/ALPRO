      "source": [
        "import os\n",
        "\n",
        "def hitung_jembatan_wheatstone():\n",
        "    # Membersihkan layar (opsional, mirip clrscr di Pascal)\n",
        "    # Gunakan 'cls' untuk Windows dan 'clear' untuk Linux/macOS\n",
        "    os.system('cls' if os.name == 'nt' else 'clear')\n",
        "\n",
        "    print(\"--- Perhitungan Jembatan Wheatstone pada Listrik Dinamis ---\")\n",
        "    print(\"============================================================\")\n",
        "    print()\n",
        "\n",
        "    try:\n",
        "        # Mengambil input dari user dan mengubahnya menjadi angka desimal (float)\n",
        "        r1 = float(input(\"Masukkan nilai R1 (Ohm): \"))\n",
        "        r2 = float(input(\"Masukkan nilai R2 (Ohm): \"))\n",
        "        r3 = float(input(\"Masukkan nilai R3 (Ohm): \"))\n",
        "\n",
        "        # Rumus Rx pada kondisi jembatan seimbang\n",
        "        # R1 * Rx = R2 * R3  =>  Rx = (R2 * R3) / R1\n",
        "        rx = (r2 * r3) / r1\n",
        "\n",
        "        print(f\"\\nNilai hambatan Rx adalah: {rx:.2f} Ohm\")\n",
        "\n",
        "    except ZeroDivisionError:\n",
        "        print(\"\\nKesalahan: R1 tidak boleh nol karena akan menyebabkan pembagian nol.\")\n",
        "    except ValueError:\n",
        "        print(\"\\nKesalahan: Mohon masukkan angka yang valid.\")\n",
        "\n",
        "    # Menahan layar agar tidak langsung tertutup (mirip readln di akhir Pascal)\n",
        "    input(\"\\nTekan Enter untuk keluar...\")\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    hitung_jembatan_wheatstone()"
      ]
    }
